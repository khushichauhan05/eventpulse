LOG_LEVEL=INFO
DATABASE_DSN=host=postgres port=5432 user=admin password=admin123 dbname=eventpulse sslmode=disable
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC_RAW=events.raw
KAFKA_TOPIC_PROCESSED=events.processed
KAFKA_TOPIC_ALERTS=alerts
KAFKA_ANALYTICS_GROUP=analytics-group
KAFKA_ALERT_GROUP=alert-group
API_PORT=8080
ANALYTICS_HEALTH_PORT=8081
ALERT_HEALTH_PORT=8082
# ML service (set to empty string to use rule-based fallback only)
ML_SERVICE_URL=http://ml-service:8000
# Redis URL for velocity feature computation in the ML service
REDIS_URL=redis://redis:6379